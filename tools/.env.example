# Standalone environment file for tools/watchlist_digest.py
# This is used by the task/cron-run watchlist digest script and is separate from the main app .env.

# Optional database paths (relative or absolute) - if not set, defaults to ../_broker_db/ztf_alerts_stream.db and ../_broker_db/users.db
ALERTS_DB_PATH="../_broker_db/ztf_alerts_stream.db"
USERS_DB_PATH="../_broker_db/users.db"

# Base URL for alert links in digest emails: Set or omit for local testing. Set to https://poibroker.uantof.cl for production
POI_BROKER_BASE_URL="http://localhost:5000" # OR https://poibroker.uantof.cl

# SMTP settings for sending emails
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=465
SMTP_USER="REPLACE_WITH_EMAIL_ADDRESS"
SMTP_APP_PASSWORD="REPLACE_WITH_APP_PASSWORD"
ADMIN_EMAIL="REPLACE_WITH_ADMIN_EMAIL_ADDRESS" # Email to receive error notifications from watchlist digest processing
