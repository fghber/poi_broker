# example private & local settings 
FLASK_ENV=development
FLASK_DEBUG=True
FLASK_TESTING=True
SECRET_KEY="REPLACE_WITH_RANDOM_SECRET_KEY"
ALERTS_DB_PATH="../_broker_db/ztf_alerts_stream.db"
USERS_DB_PATH="../_broker_db/users.db"
# example production settings
#FLASK_ENV=production
#FLASK_DEBUG=False
#FLASK_TESTING=False
# example secret key for authenticated SMTP
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=465
SMTP_USER="REPLACE_WITH_EMAIL_ADDRESS"
SMTP_APP_PASSWORD="REPLACE_WITH_APP_PASSWORD"
#SMTP_SUBJECT="Notification from POI Broker"
#SMTP_FROM #to set "from" email address alias, if different from SMTP_USER
#LOCAL_HOST=localhost OR poibroker.uantof.cl #used for SMTPLib to improve email deliverability
# Session and cookie settings
#SESSION_COOKIE_SECURE=False
#REMEMBER_COOKIE_SECURE=False
#SESSION_COOKIE_SAMESITE=Lax
#REMEMBER_COOKIE_SAMESITE=Lax
#SESSION_LIFETIME_HOURS=24
# Rate limiting settings
#RATELIMIT_ENABLED=True
#RATELIMIT_STORAGE_URI=memory://
#AUTH_RATE_LIMIT_LOGIN=10 per minute
#AUTH_RATE_LIMIT_SIGNUP=5 per hour
#AUTH_RATE_LIMIT_FORGOT_PASSWORD=5 per hour
#AUTH_RATE_LIMIT_RESET_PASSWORD=10 per hour
#AUTH_RATE_LIMIT_CHANGE_PASSWORD=10 per hour